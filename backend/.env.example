# Copy this file to .env and fill in your values

# Required: Anthropic API key with Managed Agents access
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: model to use (default: claude-sonnet-4-6)
# Switch to claude-opus-4-7 for stronger reasoning at higher cost
INFRAGUARD_MODEL=claude-sonnet-4-6

# Optional: comma-separated CORS origins (default: localhost dev + prod portfolio)
INFRAGUARD_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://asbury.resume.miyagitrades.com

# Optional: bind port (default: 8000)
INFRAGUARD_PORT=8000

# Optional: real GitHub integration. When GITHUB_TOKEN is set, the agent opens
# real PRs against the configured lab repo. Unset it to fall back to mock mode.
# Fine-grained PAT scoped to the lab repo only: contents:write, pull-requests:write.
GITHUB_TOKEN=
GITHUB_OWNER=asellers3rd
GITHUB_REPO=infraguard-lab
GITHUB_DEFAULT_BRANCH=main
